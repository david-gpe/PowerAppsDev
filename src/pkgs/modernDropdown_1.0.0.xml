    <require type="javascript" src="/ctrllib/shared/js/PowerAppsControlsFluentIcons.js" />
    <require type="javascript" src="js/modernDropdown.js" />
    <require type="other" src="/ctrllib/combobox/data/ComboBoxSample.xlsx" authoringOnly="true" />
