  <content><![CDATA[]]></content>
  <properties>
    <property name="ItemDisplayText" localizedName="##dropdown_ItemDisplayText##" datatype="string" direction="in" defaultValue="ThisItem.Value1" isExpr="true">
      <title>Display label text</title>
      <appMagic:category>data</appMagic:category>
      <appMagic:displayName>##dropdown_ItemDisplayText_DisplayName##</appMagic:displayName>
      <appMagic:tooltip>##dropdown_ItemDisplayText_Tooltip##</appMagic:tooltip>
