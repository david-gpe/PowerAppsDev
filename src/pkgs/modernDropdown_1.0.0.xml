    </property>
    <property name="Items" localizedName="##dropdown_Items##" datatype="Array" direction="in" isPrimaryInputProperty="true">
      <title>List items</title>
      <appMagic:category>data</appMagic:category>
      <appMagic:displayName>##dropdown_Items_DisplayName##</appMagic:displayName>
      <appMagic:sampleDataSource name="ComboBoxSample" location="/ctrllib/combobox/data/ComboBoxSample.xlsx" />
      <appMagic:tooltip>##dropdown_Items_Tooltip##</appMagic:tooltip>
      <appMagic:thisItemInput />
    </property>
    <property name="Default" localizedName="##dropdown_Default##" datatype="object" direction="in" isTypeBoundToPrimaryInput="true">
