<widget xmlns="http://openajax.org/metadata" xmlns:appMagic="http://schemas.microsoft.com/appMagic" spec="1.0" id="http://microsoft.com/appmagic/modernDropdown" name="modernDropdown" jsClass="AppMagic.Controls.ModernDropdownControl" version="1.0.0" styleable="true" enabledForFeatureGate="Controls.ModernDropdownControl" runtimeCost="1">
